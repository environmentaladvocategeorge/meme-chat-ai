# Secrets for the Functions emulator. Copy this file to `.secret.local`
# (gitignored) and fill in real values. The emulator loads `.secret.local`
# automatically for every defineSecret(...) used in functions/src.
#
# To pull the real production values instead of typing them by hand:
#   firebase functions:secrets:access OPENAI_API_KEY > /tmp/k && ...
# or just paste a dev/test key here. KLIPY and the RevenueCat webhook auth are
# optional locally — leave them blank to disable those features in the emulator.

OPENAI_API_KEY=
KLIPY_APP_KEY=
REVENUECAT_WEBHOOK_AUTH=
