{
  "expo": {
    "name": "Meme Chat AI",
    "slug": "meme-chat-ai",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "memechatai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jorgejimenez.memeai",
      "icon": "./assets/images/app-icon.png",
      "supportsTablet": true,
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "en",
        "CFBundleLocalizations": [
          "en",
          "es",
          "fr",
          "pt",
          "de",
          "zh",
          "ja",
          "hi",
          "ru"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jorgejimenez.memeai",
      "icon": "./assets/images/app-icon.png",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 210,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#0E0F12"
          }
        }
      ],
      "expo-localization",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow Meme Chat AI to save memes and GIFs you download to your photo library.",
          "photosPermission": "Allow Meme Chat AI to save memes and GIFs you download to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Meme Chat AI to attach photos from your library to the chat.",
          "cameraPermission": "Allow Meme Chat AI to take a photo to send in the chat."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-4560445083665704~1466844111",
          "androidAppId": "ca-app-pub-4560445083665704~1466844111",
          "delayAppMeasurementInit": true
        }
      ]
    ],
    "locales": {
      "en": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "es": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "fr": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "pt": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "de": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "zh": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "ja": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "hi": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "ru": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b448a7c7-a670-4407-a0fb-6cd180742929"
      }
    },
    "owner": "jjimenez123"
  }
}
