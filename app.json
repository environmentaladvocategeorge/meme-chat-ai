{
  "expo": {
    "name": "Meme Chat AI",
    "slug": "meme-chat-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "memechatai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jorgejimenez.memeai",
      "icon": "./assets/images/app-icon.png",
      "supportsTablet": true,
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "en",
        "CFBundleLocalizations": [
          "en",
          "es"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jorgejimenez.memeai",
      "icon": "./assets/images/app-icon.png",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "imageWidth": 210,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#0E0F12"
          }
        }
      ],
      "expo-localization",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow Meme Chat AI to save memes and GIFs you download to your photo library.",
          "photosPermission": "Allow Meme Chat AI to save memes and GIFs you download to your photo library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Meme Chat AI to attach photos from your library to the chat.",
          "cameraPermission": "Allow Meme Chat AI to take a photo to send in the chat."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "locales": {
      "en": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      },
      "es": {
        "ios": {
          "CFBundleDisplayName": "Meme Chat AI"
        }
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "%EAS_PROJECT_ID%"
      }
    }
  }
}
