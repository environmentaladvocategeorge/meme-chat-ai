# Firebase Web SDK config. Find these in Firebase Console -> Project
# Settings -> General -> Your apps -> Web app -> SDK setup and configuration.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# RevenueCat config. Find API keys in RevenueCat Dashboard -> Project Settings
# -> API Keys. Leave the platform keys blank to disable the subscription layer;
# the store will no-op gracefully.
#
# Set USE_TEST_STORE=true with a TEST_API_KEY to point local builds at the
# RevenueCat test store (overrides the platform keys when enabled).
EXPO_PUBLIC_REVENUECAT_USE_TEST_STORE=
EXPO_PUBLIC_REVENUECAT_ENABLE_CUSTOMER_CENTER=
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default

# Google AdMob config. App IDs (the ~ ones) live in app.json's
# react-native-google-mobile-ads plugin; the unit IDs (the / ones) live here.
# Find them in AdMob -> Apps -> <app> -> Ad units. Ads only render in a real
# dev/standalone build (never Expo Go) and only for Free users. Leave a banner
# ID blank or prefixed with REPLACE_WITH_ to fall back to Google test ads in dev.
# Set ADS_ENABLED=false to disable ads entirely.
EXPO_PUBLIC_ADS_ENABLED=true
EXPO_PUBLIC_ADMOB_IOS_BANNER_ID=
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=
# Rewarded ads are scaffolded but not shown yet — leave blank until a rewarded
# unit exists.
EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID=
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID=
