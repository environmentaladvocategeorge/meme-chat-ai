rules_version = '2';

// All mutations to profiles/ are performed server-side via Cloud Functions
// (onUserCreated bootstrap + deleteMyAccount cleanup) using the Admin SDK,
// which bypasses these rules. Clients can only READ their own profile doc.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /profiles/{uid} {
      allow get: if isOwner(uid) && emailVerified();
      allow list: if false;
      allow create, update, delete: if false;
    }

    // Long-term user memory. The owner can READ their facts (settings screen)
    // and CLEAR them (via the clearMemory callable, Admin SDK) — but never write
    // or EDIT: there is no client create/update path. The compiled `block` on the
    // parent doc is backend-only (the agent reads it server-side).
    match /memories/{uid} {
      // Owner may READ their state (on/off, last-updated, the compiled block —
      // all their own data). Writes are server-only (clearMemory/setMemoryEnabled
      // callables + the extraction job).
      allow get: if isOwner(uid) && emailVerified();
      allow list: if false;
      allow create, update, delete: if false;

      match /facts/{factId} {
        allow get, list: if isOwner(uid) && emailVerified();
        allow create, update, delete: if false;
      }
    }

    // Public app config (force-update floor + store URL). Must be readable
    // before sign-in so the update gate works for signed-out users. A single
    // known doc (config/app); never listable or client-writable.
    match /config/{docId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /personas/{personaId} {
      allow read: if resource.data.isEnabled == true;
      allow write: if false;
    }

    match /platform_prompts/{promptId} {
      allow read, write: if false;
    }

    // User-built personas. The owner reads their own docs (builder list/edit
    // screens); every write goes through the savePersona/deletePersona
    // callables (Admin SDK) so validation + moderation can never be skipped.
    // List queries must filter ownerUid == request.auth.uid to satisfy the
    // read rule.
    match /user_personas/{personaId} {
      allow get, list: if signedIn() && emailVerified()
        && resource.data.ownerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Written exclusively by Cloud Functions (Admin SDK) when a message or
    // name is flagged for hate speech. No client should ever read or write
    // this collection directly.
    match /flagged_messages/{docId} {
      allow read, write: if false;
    }

    match /persona_prompts/{promptId} {
      allow read, write: if false;
    }

    match /conversations/{cid} {
      allow get: if signedIn() && emailVerified() && resource.data.uid == request.auth.uid;
      allow list: if signedIn() && emailVerified();
      allow create, update, delete: if false;

      match /messages/{mid} {
        allow get, list: if signedIn() && emailVerified()
          && get(/databases/$(database)/documents/conversations/$(cid)).data.uid == request.auth.uid;
        allow create, update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
